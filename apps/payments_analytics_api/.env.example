# Токен для запуска endpoint-а из Google Apps Script:
# Authorization: Bearer <token>
GOOGLE_SHEETS_WEBHOOK_TOKEN=change_me

# Основной проект монтируется в контейнер по этому пути.
PAYMENTS_ANALYZE_PROJECT_DIR=/app/project

# Команда запуска production combined job внутри основного проекта.
PAYMENTS_ANALYZE_COMMAND=python main.py update_payments_analyze_with_ved

# Максимальное время выполнения job в секундах.
PAYMENTS_ANALYZE_TIMEOUT_SECONDS=900

# Настройки API
API_HOST=0.0.0.0
API_PORT=8000
