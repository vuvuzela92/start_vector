# Токен для защищенного webhook endpoint-а.
# Значение должно совпадать с токеном в Google Apps Script.
GOOGLE_SHEETS_WEBHOOK_TOKEN=replace_with_generated_secret_token

# Основной проект монтируется в контейнер по этому пути.
PAYMENTS_ANALYZE_PROJECT_DIR=/app/project

# Команда запуска существующей production-job внутри основного проекта.
PAYMENTS_ANALYZE_COMMAND=python -c "from src_oop.jobs.calculation_of_purchases_china.run import update_orders_white_balance_analytics; update_orders_white_balance_analytics()"

# Максимальное время выполнения job в секундах.
PAYMENTS_ANALYZE_TIMEOUT_SECONDS=900
